# ============================================
# 마젤란 대시보드 환경변수
# ============================================
# 이 파일을 .env.local 로 복사한 뒤 실제 키를 넣으세요.
# (.env.local 은 .gitignore 에 포함되어 Git 에 올라가지 않습니다)

# FRED API 키 (미국 2Y/10Y 금리)
# 발급: https://fred.stlouisfed.org/docs/api/api_key.html  (무료, 30초 소요)
FRED_API_KEY=

# 한국은행 ECOS API 키 (국고채 3Y/10Y)
# 발급: https://ecos.bok.or.kr/api/  (무료, 당일 승인)
ECOS_API_KEY=

# Yahoo Finance는 API 키 불필요
